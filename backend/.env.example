# ── Database ──────────────────────────────────────────────────────────────────
# Supabase: Project → Settings → Database → Connection string (URI)
# For local PostgreSQL: postgresql://user:password@localhost:5432/hotchickz
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Set to "false" only for a local PostgreSQL instance without SSL
USE_SSL=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://hotchickzoffer.com,http://localhost:5173

# ── GoHighLevel API ────────────────────────────────────────────────────────────
# Secret shared between this API and the GHL workflow Action 1 (Webhook).
# GHL workflow → Webhook action → Headers → Key: x-api-key | Value: <this>
# Set PRE_REGISTER_API_KEY on Render → Environment to the same value.
PRE_REGISTER_API_KEY=your_secret_key_here
