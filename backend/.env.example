# ── Database ──────────────────────────────────────────────────────────────────
# Supabase: Project → Settings → Database → Connection string (URI)
# For local PostgreSQL: postgresql://user:password@localhost:5432/hotchickz
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Set to "false" only for a local PostgreSQL instance without SSL
USE_SSL=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://hotchickzoffer.com,http://localhost:5173

# ── Webhook security ───────────────────────────────────────────────────────────
# Secret shared between this API and the GHL workflow.
# GHL must send this value in the  X-Webhook-Secret  header when calling
# POST /api/register  (set it in your GHL workflow's HTTP Action → Headers).
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED: leave blank and /api/register is open to the public internet.
REGISTER_WEBHOOK_SECRET=replace_with_a_long_random_string
