# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
USE_SSL=true

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://hotchickzoffer.com,http://localhost:5173

# ── Frontend (prefix with VITE_ so Vite exposes it to the browser) ─────────────
# Leave empty in development — the Vite proxy handles /api → localhost:8000
VITE_API_URL=https://hotchickz-api.onrender.com
